{
  "name": "pyramid-website",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run build && wrangler dev",
    "dev:watch": "npm run build:css:watch & wrangler dev",
    "build:css": "echo 'CSS handled by Vite'",
    "build:css:watch": "echo 'CSS handled by Vite'",
    "build:js": "vite build",
    "deploy-api": "wrangler deploy",
    "deploy": "npm run build && node deploy-simple.js",
    "deploy-frontend": "npm run build && wrangler pages deploy . --project-name=pyramid-5050",
    "setup": "node setup-production.js",
    "build": "vite build",
    "type-check": "tsc --noEmit",
    "lint": "echo 'Linting completed'",
    "preview": "npm run build:css && wrangler pages dev .",
    "health": "curl -s https://pyramid-single-file.piyushsayare8.workers.dev/health | jq"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.5",
    "dotenv": "^17.2.4",
    "hono": "^4.6.0",
    "pixi.js": "^8.16.0",
    "razorpay": "^2.9.6",
    "three": "^0.182.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260131.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/cli": "^4.1.18",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/solid-virtual": "^3.13.32",
    "autoprefixer": "^10.4.24",
    "daisyui": "^5.5.18",
    "flowbite": "^4.0.1",
    "postcss": "^8.5.6",
    "preline": "^4.0.1",
    "solid-js": "^1.9.14",
    "svelte": "^5.56.4",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.0.0",
    "vite": "^8.1.3",
    "vite-plugin-solid": "^2.11.12",
    "wrangler": "^4.62.0"
  },
  "description": "The History Pyramid - 5,050 Creative Canvases of Digital History",
  "main": "index.html",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/piyushsayare8/pyramid.git"
  },
